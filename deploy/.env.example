# ---------------------------------------------------------------------------
# Live-execution config for the VPS. Copy to `.env` and fill in on the SERVER.
# NEVER commit real keys. Keep API key permission = TRADE ONLY (withdraw OFF).
# ---------------------------------------------------------------------------

# Start on the Bybit TESTNET (fake money) until execution is proven. 1 = testnet.
EXCHANGE_TESTNET=1

# Bybit API credentials (create on testnet first: testnet.bybit.com)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- master safety switches -------------------------------------------------
# EXEC_ENABLED=1 turns on the executor in the live loop (sizes + LOGS order plans
#   for each ENTRY). Leave 0 for a pure signal/paper bot. The GitHub Actions scan
#   must keep this OFF (it has no ccxt). Set 1 only on the VPS/uDroid.
# LIVE_TRADING=0 keeps paper mode (no exchange orders at all).
# EXEC_DRY_RUN=1 makes the executor LOG intended orders instead of sending them.
# Real orders require LIVE_TRADING=1 AND EXEC_DRY_RUN=0 — but live SENDING is not
#   implemented until Fase 3, so keep EXEC_DRY_RUN=1 for now.
EXEC_ENABLED=1
LIVE_TRADING=0
EXEC_DRY_RUN=1
# Equity (USDT) used for sizing when no API key/network is available (DRY-RUN).
EXEC_DRY_EQUITY=1000

# --- risk -------------------------------------------------------------------
EXEC_LEVERAGE=7            # isolated leverage (SL cap 6% << ~13% liquidation @7x)
EXEC_MARGIN_MODE=isolated
EXEC_MAX_CONCURRENT=3      # max simultaneous open positions
# Sizing mode — how big each trade is:
#   risk_usd     : lose exactly EXEC_FIXED_USD at SL (= 1R). Backtest R maps to $
#                  directly (e.g. +122R * $3 ~= $366). BEST for a small account.
#   risk_pct     : lose EXEC_RISK_PCT of equity at SL (grows with the account).
#   margin_usd   : commit EXEC_FIXED_USD as margin (position = fixed * leverage).
#   notional_usd : position value = EXEC_FIXED_USD.
EXEC_SIZE_MODE=risk_usd    # "$3 per trade" as requested
EXEC_FIXED_USD=3           # the $3
EXEC_RISK_PCT=0.02         # only used when EXEC_SIZE_MODE=risk_pct
