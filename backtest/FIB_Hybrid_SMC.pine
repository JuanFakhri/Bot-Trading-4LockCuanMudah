//@version=6
// =============================================================================
//  FIB HYBRID + SMC CONFLUENCE  —  BACKTEST ONLY
// -----------------------------------------------------------------------------
//  Tujuan: MENGUJI usulan tambahan (SMC, ADX, ATR, volume, premium/discount,
//  BTC.D/USDT.D/DXY/TOTAL3, sesi, multi-TF) DI ATAS strategi FIB Hybrid, SEBELUM
//  dimasukkan ke bot live. Setiap komponen bisa di-toggle & diberi bobot skor,
//  jadi Anda bisa lihat mana yang benar-benar menambah edge (bukan asal AND).
//
//  Cara pakai:
//   1. Tempel di TradingView Pine Editor → Add to chart.
//   2. Jalankan pada chart 1H (entry) untuk pair USDT (mis. ETHUSDT).
//   3. Buka Strategy Tester → bandingkan winrate/PF saat toggle dinyalakan/dimatikan.
//   4. Uji periode out-of-sample (mis. set tanggal berbeda) sebelum percaya hasil.
//
//  CATATAN JUJUR:
//   - Deteksi SMC (sweep/CHOCH/BOS/FVG/OB) di Pine bersifat HEURISTIK/perkiraan,
//     bukan definisi diskresioner sempurna. Gunakan untuk perbandingan relatif.
//   - request.security memakai lookahead_off + konfirmasi [1] agar tidak repaint.
//   - News filter (CPI/FOMC/NFP) TIDAK ADA di sini (Pine tak punya feed kalender);
//     itu diterapkan di bot live, bukan di backtest ini.
// =============================================================================

strategy("FIB Hybrid + SMC Confluence [Backtest]", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.05,
     slippage=2, pyramiding=0, calc_on_order_fills=false, process_orders_on_close=true)

// ------------------------------------------------------------------ INPUTS ----
gCore = "1) Inti FIB"
pivotLen   = input.int(5,   "Panjang pivot swing",        group=gCore, minval=2)
minAtrMult = input.float(3.0,"Impuls minimal (x ATR)",    group=gCore, step=0.5)
fibLo      = input.float(0.5, "Golden zone bawah",        group=gCore, step=0.01)
fibHi      = input.float(0.618,"Golden zone atas",        group=gCore, step=0.01)
fibInval   = input.float(0.786,"Batal jika retrace >",    group=gCore, step=0.01)
fibExt     = input.float(1.272,"TP3 fib extension",       group=gCore, step=0.01)

gFilt = "2) Filter (toggle)"
useMultiTF   = input.bool(true,  "Searah HTF (D & 4H & 1H)", group=gFilt)
usePremDisc  = input.bool(true,  "Premium/Discount",         group=gFilt)
useADX       = input.bool(true,  "ADX > ambang",             group=gFilt)
useATR       = input.bool(true,  "ATR dalam rentang",        group=gFilt)
useVolume    = input.bool(true,  "Volume spike > SMA20",     group=gFilt)
useSession   = input.bool(false, "Hanya sesi London/NY",     group=gFilt)
useSMC       = input.bool(true,  "SMC (Sweep+CHOCH+BOS)",    group=gFilt)
useFVG       = input.bool(true,  "Butuh FVG",                group=gFilt)
useOB        = input.bool(false, "Butuh Order Block",        group=gFilt)
useBTCD      = input.bool(false, "BTC.D searah (alt)",       group=gFilt)
useUSDTD     = input.bool(true,  "USDT.D (EMA50/RSI/struktur)",group=gFilt)
useDXY       = input.bool(false, "DXY searah",               group=gFilt)
useTOTAL3    = input.bool(false, "TOTAL3 HH/HL",             group=gFilt)

gAdx = "3) Parameter indikator"
adxLen    = input.int(14, "ADX length",       group=gAdx)
adxTh     = input.float(25,"ADX minimal",     group=gAdx)
atrLen    = input.int(14, "ATR length",       group=gAdx)
atrMinPct = input.float(0.3,"ATR min (% harga)",group=gAdx, step=0.1)
atrMaxPct = input.float(8.0,"ATR maks (% harga)",group=gAdx, step=0.5)
sweepLook = input.int(10, "Lookback liquidity sweep", group=gAdx)
rsiLen    = input.int(14, "RSI length",       group=gAdx)

gScore = "4) AI Score (bobot #15)"
useScore  = input.bool(true, "Aktifkan gerbang skor", group=gScore)
scoreTh   = input.float(85, "Entry bila skor >=",     group=gScore, step=1)
wEMA   = input.float(10, "EMA",     group=gScore)
wRSI   = input.float(5,  "RSI",     group=gScore)
wADX   = input.float(10, "ADX",     group=gScore)
wFib   = input.float(15, "Fib",     group=gScore)
wSweep = input.float(15, "Sweep",   group=gScore)
wChoch = input.float(15, "CHOCH",   group=gScore)
wBOS   = input.float(10, "BOS",     group=gScore)
wFVG   = input.float(10, "FVG",     group=gScore)
wOB    = input.float(5,  "OB",      group=gScore)
wBTCD  = input.float(5,  "BTC.D",   group=gScore)
wUSDTD = input.float(5,  "USDT.D",  group=gScore)
wDXY   = input.float(5,  "DXY",     group=gScore)

gRisk = "5) Risk & Exit"
riskPerc = input.float(1.0,"Risk per trade (%)", group=gRisk, step=0.25)
slAtr    = input.float(1.0,"SL = x ATR di luar swing", group=gRisk, step=0.25)
slCapPct = input.float(6.0,"SL maks (%)",       group=gRisk, step=0.5)
tp1Perc  = input.float(30, "TP1 % posisi",      group=gRisk)
tp2Perc  = input.float(30, "TP2 % posisi",      group=gRisk)
useTrail = input.bool(true,"Trailing EMA20 stlh TP1", group=gRisk)
cdLoss   = input.int(8,  "Cooldown stlh loss (bar)", group=gRisk)
cdWin    = input.int(2,  "Cooldown stlh win (bar)",  group=gRisk)

// ------------------------------------------------------------- INDICATORS ----
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
ema20  = ta.ema(close, 20)
rsi    = ta.rsi(close, rsiLen)
atr    = ta.atr(atrLen)
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
volSma = ta.sma(volume, 20)

// Non-repaint higher-timeframe trend (confirmed bar only)
f_trend(tf) =>
    e50  = request.security(syminfo.tickerid, tf, ta.ema(close,50)[1],  lookahead=barmerge.lookahead_off)
    e200 = request.security(syminfo.tickerid, tf, ta.ema(close,200)[1], lookahead=barmerge.lookahead_off)
    e50 > e200 ? 1 : e50 < e200 ? -1 : 0

tD  = f_trend("D")
t4  = f_trend("240")
t1  = f_trend("60")
bullTF = tD==1  and t4==1  and t1==1
bearTF = tD==-1 and t4==-1 and t1==-1

// ------------------------------------------------------------ FIB IMPULSE ----
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)
var float swH = na
var float swL = na
var int   swHbar = na
var int   swLbar = na
if not na(ph)
    swH := ph
    swHbar := bar_index - pivotLen
if not na(pl)
    swL := pl
    swLbar := bar_index - pivotLen

// bull impulse = swing low lalu swing high; retrace = seberapa turun dari high
bullImpulse = not na(swH) and not na(swL) and swHbar > swLbar and (swH - swL) >= minAtrMult*atr
bearImpulse = not na(swH) and not na(swL) and swLbar > swHbar and (swH - swL) >= minAtrMult*atr

bullRetr = bullImpulse ? (swH - close) / (swH - swL) : na
bearRetr = bearImpulse ? (close - swL) / (swH - swL) : na

bullFib = bullImpulse and bullRetr >= fibLo and bullRetr <= fibHi and bullRetr < fibInval
bearFib = bearImpulse and bearRetr >= fibLo and bearRetr <= fibHi and bearRetr < fibInval

mid = na(swH) or na(swL) ? na : (swH + swL)/2
discount = not na(mid) and close < mid   // di bawah 50% = discount
premium  = not na(mid) and close > mid

// --------------------------------------------------------------- SMC (heur) ---
priorLow  = ta.lowest(low,  sweepLook)[1]
priorHigh = ta.highest(high, sweepLook)[1]
// liquidity sweep: tembus likuiditas lalu reclaim di candle yg sama
sweepBull = low < priorLow  and close > priorLow
sweepBear = high > priorHigh and close < priorHigh
// CHOCH: harga menembus balik swing terakhir (perubahan karakter)
chochBull = not na(swH) and ta.crossover(close, swH)
chochBear = not na(swL) and ta.crossunder(close, swL)
// BOS: konfirmasi break struktur searah tren
bosBull = not na(swH) and close > swH
bosBear = not na(swL) and close < swL
// FVG (3-bar imbalance) + harga retest ke dalam gap
fvgBullExists = low[0] > high[2]
fvgBearExists = high[0] < low[2]
var float fvgBullTop = na
var float fvgBullBot = na
var float fvgBearTop = na
var float fvgBearBot = na
if fvgBullExists
    fvgBullTop := low[0]
    fvgBullBot := high[2]
if fvgBearExists
    fvgBearTop := low[2]
    fvgBearBot := high[0]
fvgBull = not na(fvgBullBot) and low <= fvgBullTop and close >= fvgBullBot
fvgBear = not na(fvgBearTop) and high >= fvgBearBot and close <= fvgBearTop
// Order block (perkiraan): candle berlawanan terakhir sebelum BOS
obBull = close[1] < open[1] and bosBull
obBear = close[1] > open[1] and bosBear

// ------------------------------------------------------- MACRO (security) ----
f_macDown(sym) =>
    e = request.security(sym, "D", ta.ema(close,50)[1], lookahead=barmerge.lookahead_off)
    c = request.security(sym, "D", close[1],            lookahead=barmerge.lookahead_off)
    c < e
btcdDown  = f_macDown("CRYPTOCAP:BTC.D")
usdtdDown = f_macDown("CRYPTOCAP:USDT.D")
dxyDown   = f_macDown("TVC:DXY")
t3Up = request.security("CRYPTOCAP:TOTAL3", "D", close[1], lookahead=barmerge.lookahead_off) >
       request.security("CRYPTOCAP:TOTAL3", "D", close[6], lookahead=barmerge.lookahead_off)

// ------------------------------------------------------------- SESSION -------
inLDN = not na(time(timeframe.period, "0700-1600", "Europe/London"))
inNY  = not na(time(timeframe.period, "0800-1700", "America/New_York"))
sessOK = not useSession or inLDN or inNY

// ---------------------------------------------------------------- SCORE ------
f_score(isLong) =>
    s = 0.0
    emaOK = isLong ? (close>ema200 and ema50>ema200) : (close<ema200 and ema50<ema200)
    rsiOK = isLong ? rsi>50 : rsi<50
    s += emaOK ? wEMA : 0
    s += rsiOK ? wRSI : 0
    s += (adx>adxTh) ? wADX : 0
    s += (isLong ? bullFib : bearFib) ? wFib : 0
    s += (isLong ? sweepBull : sweepBear) ? wSweep : 0
    s += (isLong ? chochBull : chochBear) ? wChoch : 0
    s += (isLong ? bosBull : bosBear) ? wBOS : 0
    s += (isLong ? fvgBull : fvgBear) ? wFVG : 0
    s += (isLong ? obBull : obBear) ? wOB : 0
    s += (isLong ? btcdDown : not btcdDown) ? wBTCD : 0
    s += (isLong ? usdtdDown : not usdtdDown) ? wUSDTD : 0
    s += (isLong ? dxyDown : not dxyDown) ? wDXY : 0
    s
longScore  = f_score(true)
shortScore = f_score(false)

// ------------------------------------------------------- HARD CONDITIONS -----
f_hard(isLong) =>
    okTF   = not useMultiTF  or (isLong ? bullTF : bearTF)
    okPD   = not usePremDisc or (isLong ? discount : premium)
    okADX  = not useADX      or adx > adxTh
    okATR  = not useATR      or ((atr/close*100) >= atrMinPct and (atr/close*100) <= atrMaxPct)
    okVol  = not useVolume   or volume > volSma
    okSMC  = not useSMC      or (isLong ? (sweepBull and (chochBull or bosBull)) : (sweepBear and (chochBear or bosBear)))
    okFVG  = not useFVG      or (isLong ? fvgBull : fvgBear)
    okOB   = not useOB       or (isLong ? obBull : obBear)
    okBTCD = not useBTCD     or (isLong ? btcdDown : not btcdDown)
    okUSDTD= not useUSDTD    or (isLong ? usdtdDown : not usdtdDown)
    okDXY  = not useDXY      or (isLong ? dxyDown : not dxyDown)
    okT3   = not useTOTAL3   or (isLong ? t3Up : not t3Up)
    okFib  = isLong ? bullFib : bearFib
    okScore= not useScore    or ((isLong ? longScore : shortScore) >= scoreTh)
    okFib and okTF and okPD and okADX and okATR and okVol and okSMC and okFVG and okOB and okBTCD and okUSDTD and okDXY and okT3 and okScore and sessOK

// -------------------------------------------------------------- COOLDOWN -----
var int cdUntil = 0
canTrade = bar_index >= cdUntil

longSig  = f_hard(true)  and canTrade and strategy.position_size == 0
shortSig = f_hard(false) and canTrade and strategy.position_size == 0

// ------------------------------------------------------------- ENTRIES -------
var float eEntry = na
var float eSL = na
var float eTP1 = na
var float eTP2 = na
var float eTP3 = na
var bool  tp1Done = false

f_qtyByRisk(entry, sl) =>
    riskAmt = strategy.equity * (riskPerc/100)
    perUnit = math.abs(entry - sl)
    perUnit > 0 ? riskAmt / perUnit : 0.0

if longSig
    swing = swL
    rawSL = math.min(swing, close) - slAtr*atr
    sl    = math.max(rawSL, close*(1-slCapPct/100))
    r     = close - sl
    eEntry := close
    eSL := sl
    eTP1 := close + r
    eTP2 := close + 2*r
    eTP3 := swH + (fibExt-1.0)*(swH-swL)   // fib extension proyeksi
    tp1Done := false
    strategy.entry("Long", strategy.long, qty=f_qtyByRisk(close, sl))

if shortSig
    swing = swH
    rawSL = math.max(swing, close) + slAtr*atr
    sl    = math.min(rawSL, close*(1+slCapPct/100))
    r     = sl - close
    eEntry := close
    eSL := sl
    eTP1 := close - r
    eTP2 := close - 2*r
    eTP3 := swL - (fibExt-1.0)*(swH-swL)
    tp1Done := false
    strategy.entry("Short", strategy.short, qty=f_qtyByRisk(close, sl))

// -------------------------------------------------------------- EXITS --------
if strategy.position_size > 0
    strategy.exit("L-TP1", from_entry="Long", qty_percent=tp1Perc, limit=eTP1, stop=eSL)
    strategy.exit("L-TP2", from_entry="Long", qty_percent=tp2Perc, limit=eTP2, stop=eSL)
    strategy.exit("L-TP3", from_entry="Long", limit=eTP3, stop=eSL)
    if high >= eTP1
        tp1Done := true
        eSL := math.max(eSL, eEntry*1.0015)     // breakeven +0.15% setelah TP1
    if useTrail and tp1Done and close < ema20
        strategy.close("Long", comment="trail EMA20")

if strategy.position_size < 0
    strategy.exit("S-TP1", from_entry="Short", qty_percent=tp1Perc, limit=eTP1, stop=eSL)
    strategy.exit("S-TP2", from_entry="Short", qty_percent=tp2Perc, limit=eTP2, stop=eSL)
    strategy.exit("S-TP3", from_entry="Short", limit=eTP3, stop=eSL)
    if low <= eTP1
        tp1Done := true
        eSL := math.min(eSL, eEntry*0.9985)
    if useTrail and tp1Done and close > ema20
        strategy.close("Short", comment="trail EMA20")

// set cooldown saat trade baru saja tertutup
if strategy.position_size == 0 and strategy.position_size[1] != 0
    won = strategy.netprofit > strategy.netprofit[1]
    cdUntil := bar_index + (won ? cdWin : cdLoss)

// ---------------------------------------------------------------- PLOTS ------
plot(ema50,  "EMA50",  color.new(color.orange,50))
plot(ema200, "EMA200", color.new(color.blue,50))
plot(ema20,  "EMA20",  color.new(color.gray,60))
plotshape(longSig,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)
plotshape(shortSig, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)
bgcolor(useSession and not sessOK ? color.new(color.gray, 92) : na, title="Luar sesi")

// tabel skor real-time
var table t = table.new(position.top_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "Long score",  text_color=color.white, bgcolor=color.new(color.green,70))
    table.cell(t, 1, 0, str.tostring(longScore,  "#"), text_color=color.white)
    table.cell(t, 0, 1, "Short score", text_color=color.white, bgcolor=color.new(color.red,70))
    table.cell(t, 1, 1, str.tostring(shortScore, "#"), text_color=color.white)
    table.cell(t, 0, 2, "Ambang", text_color=color.white)
    table.cell(t, 1, 2, str.tostring(scoreTh, "#"), text_color=color.white)
    table.cell(t, 0, 3, "ADX", text_color=color.white)
    table.cell(t, 1, 3, str.tostring(adx, "#.0"), text_color=color.white)
